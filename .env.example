SECRET_KEY=change-this-to-a-random-value
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Deja POSTGRES_HOST vacío para usar SQLite en local sin Docker.
POSTGRES_HOST=
POSTGRES_DB=pqr
POSTGRES_USER=pqr
POSTGRES_PASSWORD=pqr
POSTGRES_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:5173

# Backend de correo: "django.core.mail.backends.console.EmailBackend" para ver
# los correos en la consola, o "django.core.mail.backends.smtp.EmailBackend"
# para enviarlos de verdad (ver docs/decisiones_arquitectura.md).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=pqr@sersocial.local
